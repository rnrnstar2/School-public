{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://school.local/lesson-factory/schemas/asset.schema.json",
  "title": "Generated Asset",
  "description": "Schema for owner-local image or video assets produced by adapters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "type",
    "source_adapter",
    "source_model",
    "prompt_used",
    "file_path",
    "metadata",
    "created_at"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "pattern": "^asset\\.[a-z0-9.-]+$"
    },
    "type": {
      "type": "string",
      "enum": [
        "image",
        "video"
      ]
    },
    "source_adapter": {
      "type": "string"
    },
    "source_model": {
      "type": "string"
    },
    "prompt_used": {
      "type": "string"
    },
    "file_path": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
