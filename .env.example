# School local environment example
#
# Copy to `.env.local` and fill only the values needed for your local task.
# Never commit `.env.local` or real provider/service credentials.

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Admin authorization
# ADMIN_EMAILS is a comma-separated list.
# ADMIN_API_KEY is optional for server-to-server maintainer tasks.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# AI provider routing
# The default local path can fall back when keys are absent, depending on feature.
# -----------------------------------------------------------------------------
ZAI_PLANNER_API_KEY=
ZAI_API_KEY=
ZAI_CODING_PLAN_API_URL=
ZAI_PLANNER_API_URL=
ZAI_PLANNER_MODEL=glm-5
DEBUG_ZAI_HEALTH=

# -----------------------------------------------------------------------------
# BYOK encryption
# 32-byte base64 keys. Generate locally with:
#   openssl rand -base64 32
# PRIMARY encrypts and decrypts. PREVIOUS is for rotation windows only.
# BYOK_ENCRYPTION_KEY is the legacy fallback when PRIMARY is absent.
# -----------------------------------------------------------------------------
BYOK_ENCRYPTION_KEY_PRIMARY=
BYOK_ENCRYPTION_KEY_PREVIOUS=
BYOK_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Mentor conductor and model routing
# -----------------------------------------------------------------------------
MENTOR_CONDUCTOR_ENABLED=1
MENTOR_FAST_INTAKE_FALLBACK=
MENTOR_MODEL_FALLBACK_ALL_GLM=
MENTOR_MODEL_CONDUCTOR=
MENTOR_MODEL_GOAL_TREE=
MENTOR_MODEL_TECH_SCOUT=
MENTOR_MODEL_TOOL_SCOUT=
MENTOR_MODEL_NON_ENG_CRITIC=
MENTOR_MODEL_PATH_PLANNER=
MENTOR_MODEL_LESSON_MATCHER=
MENTOR_MODEL_MEMORY_RECALL=
MENTOR_MODEL_JUDGE=
MENTOR_MODEL_TIE_BREAKER=

# -----------------------------------------------------------------------------
# Phase 3 provider opt-in
# Leave unset unless you are intentionally testing direct provider calls.
# -----------------------------------------------------------------------------
MENTOR_PROVIDER_PHASE3=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Per-user monthly model budget cap
# -----------------------------------------------------------------------------
MENTOR_USER_MONTHLY_BUDGET_CAP_USD=5.0

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Product analytics
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Site URL
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Transactional email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
NOTIFICATION_EMAIL_FROM=School <noreply@example.com>

# -----------------------------------------------------------------------------
# Cron / scheduler
# -----------------------------------------------------------------------------
CRON_SECRET=
SCHEDULER_CONFIG_PATH=config/scheduler.yaml
SCHEDULER_TIMEZONE=Asia/Tokyo
SCHEDULER_BASELINE_CRON=0 2 * * *
SCHEDULER_CRON_MATCHER_SWEEP=
SCHEDULER_CRON_GAP_SCAN=
SCHEDULER_CRON_PROPOSER_RUN=
SCHEDULER_CRON_JUDGE_RUN=
SCHEDULER_CRON_NIGHTLY_DIGEST=

# -----------------------------------------------------------------------------
# Upstash Redis for distributed rate limiting
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
