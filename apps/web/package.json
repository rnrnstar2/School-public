{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint",
    "supabase:typegen": "sh -c ': \"Treat 401/403 as reachable; this probe checks network reachability only.\"; code=$(curl -sS --max-time 5 -o /dev/null -w \"%{http_code}\" http://127.0.0.1:54341/rest/v1/ 2>/dev/null); code=${code:-000}; if [ \"$code\" = \"000\" ]; then echo \"Local Supabase is not reachable on http://127.0.0.1:54341/rest/v1/. Start it with supabase start.\" >&2; exit 1; fi; node scripts/supabase/gen-types-safe.mjs'",
    "supabase:typegen:check": "pnpm run supabase:typegen && git diff --exit-code -- src/lib/supabase/database.types.ts",
    "debug:zai-snapshot": "node --import tsx scripts/zai-snapshot.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/lib/**/*.test.ts",
    "test:vitest": "vitest run",
    "test:rls-live": "RUN_LIVE_RLS_TESTS=1 vitest run src/test/rls-*.live.spec.ts",
    "test:all": "tsx --test src/**/*.test.ts && vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@base-ui/react": "^1.2.0",
    "@google/generative-ai": "^0.24.1",
    "@school/flywheel-scheduler": "workspace:*",
    "@react-pdf/renderer": "^4.3.2",
    "@school/ui": "workspace:*",
    "@sentry/nextjs": "^10.43.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/og": "^0.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.0",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.37.0",
    "posthog-js": "^1.360.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^29.0.0",
    "mermaid": "^11.10.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
